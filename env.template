# Copy this file to .env for local use. Never commit .env to git.
# In cloud routines, set these as environment variables on the routine itself.
# DO NOT create a .env file in the cloud — it will leak secrets.

# Alpaca — use paper trading URL to start, switch to live when ready
# Paper:  https://paper-api.alpaca.markets/v2
# Live:   https://api.alpaca.markets/v2
ALPACA_ENDPOINT=https://paper-api.alpaca.markets/v2
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets/v2
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Perplexity (market research)
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=sonar

# Telegram (notifications — bot sends messages to your chat)
# Setup: create a bot via @BotFather in Telegram, then get your chat_id from
# https://api.telegram.org/bot<TOKEN>/getUpdates after messaging your bot once
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
